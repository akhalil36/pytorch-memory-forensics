{
    "name": "CNN CIFAR10 DATASET DEV CONTAINER",
    "build": {
        "dockerfile": "../Dockerfile"
    },
    "workspaceFolder": "/app",
    // "mounts": [
    //     "source=${localWorkspaceFolder}, target=/app,type=bind"
    // ],
    "mounts": [
        "source=${localWorkspaceFolder},target=/app,type=bind"
    ],
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt=seccomp=unconfined"
        ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-vscode.cpptools"
            ]
        }
    },
    "remoteUser": "root"
}